#!/usr/bin/env python3
import argparse
import re
import shutil
import subprocess


def list_local_ips() -> list[str]:
    inet_matcher = re.compile(r"^\s*inet ((?:[0-9]{1,3}\.){3}[0-9]{1,3})")

    if shutil.which("ifconfig"):
        output = subprocess.check_output(["ifconfig", "-a"], text=True)
    elif shutil.which("ip"):
        output = subprocess.check_output(["ip", "-4", "addr", "show"], text=True)
    else:
        raise RuntimeError("neither 'ifconfig' nor 'ip' found on PATH")

    ip_addrs = [m.group(1) for line in output.splitlines() if (m := inet_matcher.search(line))]

    # Hide loopback unless it's the only address.
    if len(ip_addrs) > 1:
        ip_addrs = [ip for ip in ip_addrs if ip != "127.0.0.1"]

    return ip_addrs


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="myip",
        description="Print this machine's IP address or a list of candidates",
    )
    parser.parse_args()

    for ip in list_local_ips():
        print(ip)


main()
