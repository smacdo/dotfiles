#!/usr/bin/env python3
"""
Author: Scott MacDonald
Purpose: Prints weather information suitable for display in a status bar.

Information about wttr.in, including the formatting options used below can be at
https://github.com/chubin/wttr.in

The format used below has the following data arranged in order:
  Location;ConditionEmoji;ConditionText;Temp;Precip;Pressure;Moon;
  Sunset;Sunrise;Humidity;FeelsLike;Wind;UVIndex;MoonDay;Dawn;Dusk
"""

# TODO: Support weather extended caching if network not available.
# TODO: Add cache busting (delete cache entry for location).
# TODO: Extract caching to _pydotlib module

import argparse
import json
import os
import logging
import sys
import tempfile
import urllib.error
import urllib.parse
import urllib.request

from dataclasses import dataclass
from datetime import datetime, timezone
from typing import Generic, TypeVar

ENV_WEATHER_LOCATION = "WEATHER_LOCATION"

logger = logging.getLogger(__name__)

T = TypeVar("T")


@dataclass
class Unit(Generic[T]):
    value: T
    unit: str

    def __str__(self):
        return f"{str(self.value)}{self.unit}"


@dataclass
class Condition:
    location: str
    cond: str
    cond_full: str
    temp: Unit[int]
    precip: Unit[float]
    pressure: Unit[int]
    moon: str
    moon_day: int
    sunset: str
    sunrise: str
    dawn: str
    dusk: str
    humidity: Unit[float]
    feels_like: Unit[int]
    wind: str
    uv_index: int

    @property
    def short_location(self) -> str:
        return self.location.split(",")[0]

    @staticmethod
    def parse(s: str) -> "Condition":
        parts = s.split(";")
        expected = 16
        if len(parts) < expected:
            raise ValueError(
                f"Unexpected wttr.in response ({len(parts)} fields, expected {expected}): {s!r}"
            )
        return Condition(
            location=parts[0],   # "kent, washington, us"
            cond=parts[1].strip(),  # "☀️" (spaces already stripped)
            cond_full=parts[2],  # "Sunny"
            # Remove '+' and '°F', then convert to int
            temp=Unit(int(parts[3].replace("+", "").replace("°F", "")), "F"),
            # Remove 'in' and convert to float
            precip=Unit(float(parts[4].replace("in", "")), "in"),
            # Remove 'hPa' and convert to int
            pressure=Unit(int(parts[5].replace("hPa", "")), "hPa"),
            moon=parts[6],
            sunset=parts[7],
            sunrise=parts[8],
            # Remove '%' and convert to int
            humidity=Unit(int(parts[9].replace("%", "")), "%"),
            # Remove '+' and '°F', then convert to int
            feels_like=Unit(int(parts[10].replace("+", "").replace("°F", "")), "F"),
            wind=parts[11],      # e.g. "↙7mph" — kept as-is, includes direction arrow
            uv_index=int(parts[12]),
            moon_day=int(parts[13]),
            dawn=parts[14],
            dusk=parts[15],
        )


def fetch_wttr(location: str | None) -> str:
    location = urllib.parse.quote(location, safe="") if location else ""
    url = f"https://wttr.in/{location}?format=%l%3B%c%3B%C%3B%t%3B%p%3B%P%3B%m%3B%s%3B%S%3B%h%3B%f%3B%w%3B%u%3B%M%3B%D%3B%d"

    logger.debug(f"Fetching {url}")

    try:
        response = urllib.request.urlopen(url)
    except urllib.error.URLError as e:
        raise RuntimeError(f"Failed to fetch weather data: {e.reason}") from e

    return response.read().decode("utf-8")


def cache_path() -> str:
    return os.path.join(
        os.environ.get("XDG_STATE_HOME", os.path.expanduser("~/.local/state")),
        "dotfiles/weather-status-cache.json",
    )


def read_cache(location: str, timeout_secs: int) -> str | None:
    path = cache_path()

    if not os.path.exists(path):
        logging.debug(f"Cache file {path} does not exist")
        return None

    try:
        with open(path) as f:
            logger.debug(f"Using cache file at {path}")
            cached_conditions = json.load(f)

            if location.lower() in cached_conditions:
                created_at_str, data = cached_conditions[location.lower()]
                created_at = datetime.fromisoformat(created_at_str)
                age_secs = (datetime.now(timezone.utc) - created_at).total_seconds()

                if age_secs < timeout_secs:
                    logger.debug(
                        f"Loaded cache key `{location}` with age {age_secs:.1f}s"
                    )
                    return data
                else:
                    logger.debug(
                        f"Rejected expired cache key `{location}` with age = {age_secs:.1f}s (max {timeout_secs}s)"
                    )
            else:
                logger.debug(f"Cache key `{location}` does not exist")
    except json.JSONDecodeError:
        logger.warning(f"Cache file {path} contains invalid JSON, ignoring")
    except (ValueError, TypeError):
        logger.warning(f"Cache file {path} has unrecognized format, ignoring")

    return None


def write_cache(location: str, data: str) -> None:
    path = cache_path()
    os.makedirs(os.path.dirname(path), exist_ok=True)

    # Read current cache entries and add this location to the entries.
    cached_conditions: dict[str, tuple[str, str]] = {}

    if os.path.exists(path):
        logger.debug(f"Using cache file at {path}")
        try:
            with open(path) as f:
                cached_conditions = json.load(f)
        except json.JSONDecodeError:
            logger.warning(f"Cache file {path} contains invalid JSON, discarding")

    created_at = datetime.now(timezone.utc).isoformat()
    cached_conditions[location.lower()] = (created_at, data)

    # Write cache back to disk.
    # TODO: locking?
    fd, tmp = tempfile.mkstemp(dir=os.path.dirname(path))

    with os.fdopen(fd, "w") as f:
        json.dump(cached_conditions, f)

    os.replace(tmp, path)

    logger.debug(
        f"Wrote to cache key = `{location}`, created_at = `{created_at}`, data = `{data}`"
    )


def current_conditions(location: str | None) -> Condition:
    cache_key = location if location else "__AUTO_LOCATION__"
    wttr_response = read_cache(cache_key, timeout_secs=5 * 60)

    if wttr_response is None:
        logger.debug(
            f"Fetch current conditions for `{location}` because it was not cached"
        )
        wttr_response = fetch_wttr(location)
        write_cache(cache_key, wttr_response)

    return Condition.parse(wttr_response)


def report_summary(c: Condition) -> str:
    return f"{c.short_location.title()} {c.temp} {c.cond}"


def report_all(c: Condition) -> str:
    return (
        f"Location: {c.location.title()}\n"
        f"Conditions: {c.cond} {c.cond_full}\n"
        f"Temperature: {c.temp} (feels like {c.feels_like})\n"
        f"Wind: {c.wind}\n"
        f"Precip: {c.precip}\n"
        f"Humidity: {c.humidity}\n"
        f"Pressure: {c.pressure}\n"
        f"UV Index: {c.uv_index}\n"
        f"Moon: {c.moon} (day {c.moon_day})\n"
        f"Dawn: {c.dawn}\n"
        f"Sunrise: {c.sunrise}\n"
        f"Sunset: {c.sunset}\n"
        f"Dusk: {c.dusk}"
    )


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Show upcoming Google Calendar meetings."
    )
    parser.add_argument(
        "--print-location",
        action="store_true",
        help="Print the location that will be looked up",
    )
    parser.add_argument(
        "--all",
        action="store_true",
        help="Show all condition fields, not just the summary",
    )
    parser.add_argument(
        "-v",
        "--verbose",
        action="store_true",
        help="Enable verbose output (DEBUG level logging)",
    )
    parser.add_argument(
        "-s",
        "--silent",
        action="store_true",
        help="Silence output except for errors",
    )
    parser.add_argument(
        "--location",
        help="Location to look up weather conditions for",
    )
    args = parser.parse_args()

    if args.verbose:
        level = logging.DEBUG
    elif args.silent:
        level = logging.ERROR
    else:
        level = logging.INFO
    logging.basicConfig(level=level, format="%(levelname)s: %(message)s")

    # Get the weather location from the arguments, or the environment variable "WEATHER_LOCATION" if
    # not provided.
    if args.location:
        location = args.location
    elif ENV_WEATHER_LOCATION in os.environ:
        logging.debug(f"Reading location from env var `{ENV_WEATHER_LOCATION}`")
        location = os.environ.get(ENV_WEATHER_LOCATION)
    else:
        location = None

    logging.debug(f"Location is {location}")

    # Print the weather location and exit early if requested.
    if args.print_location:
        print(location)
        return 0

    # Print the current conditions
    try:
        c = current_conditions(location)
    except (RuntimeError, ValueError) as e:
        logger.error(str(e))
        return 1

    if args.all:
        print(report_all(c))
    else:
        print(report_summary(c))

    return 0


if __name__ == "__main__":
    sys.exit(main())
