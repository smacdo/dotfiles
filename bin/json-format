#!/bin/sh
# Pretty prints JSON text to the command line.

print_help() {
  echo "Pretty print JSON text from stdin or a file to the terminal."
  echo "Usage: $(basename "$0") [-f path/to/input]"
}

main() {
  while getopts 'hf:' opt; do
    case "$opt" in
      h) print_help; exit ;;
      f) input_file="$OPTARG" ;;
      ?) print_help; exit 2 ;;
    esac
  done

  shift "$((OPTIND - 1))"

  if [ -n "$input_file" ]; then
    if [ ! -f "$input_file" ]; then
      printf '[ERROR]: Input file does not exist: %s\n' "$input_file" >&2
      exit 3
    fi
    python3 -m json.tool < "$input_file"
  else
    python3 -m json.tool "$@"
  fi
}

main "$@"
